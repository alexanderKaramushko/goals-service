# Окружение, в котором запускается сервер
NODE_ENV=development

# Порт сервиса
SERVICE_PORT=3000

# Хост базы даных
POSTGRES_DB_HOST=localhost

# Название базы данных
POSTGRES_DB_NAME=goals-test

# Имя пользователя БД
POSTGRES_DB_USER=postgres

POSTGRES_DB_PASSWORD=test

# Порт базы данных
POSTGRES_DB_PORT=54320

# Хост микросервиса, к которому подключается сервис
MICROSERVICE_HOST=localhost

# Порт микросервиса, к которому подключается сервис
MICROSERVICE_PORT=3002

# БД connection string
DATABASE_URL=postgres://postgres:test@localhost:54320/goals-test

# Максимально допустимый порог просроченных шагов на цели
MAX_OUTDATED_STEPS_PERCENTAGE=20